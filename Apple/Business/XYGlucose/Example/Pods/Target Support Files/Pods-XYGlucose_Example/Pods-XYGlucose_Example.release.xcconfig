ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CocoaLumberjack" "${PODS_CONFIGURATION_BUILD_DIR}/DeviceKit" "${PODS_CONFIGURATION_BUILD_DIR}/MTBleCore" "${PODS_CONFIGURATION_BUILD_DIR}/XYApp" "${PODS_CONFIGURATION_BUILD_DIR}/XYCmd" "${PODS_CONFIGURATION_BUILD_DIR}/XYCoreBluetooth" "${PODS_CONFIGURATION_BUILD_DIR}/XYExtension" "${PODS_CONFIGURATION_BUILD_DIR}/XYGlucose" "${PODS_CONFIGURATION_BUILD_DIR}/XYLog" "${PODS_CONFIGURATION_BUILD_DIR}/XYNetwork" "${PODS_CONFIGURATION_BUILD_DIR}/XYStorage" "${PODS_CONFIGURATION_BUILD_DIR}/XYUser" "${PODS_CONFIGURATION_BUILD_DIR}/XYUtil" "${PODS_CONFIGURATION_BUILD_DIR}/XYWatchConnectivity"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CocoaLumberjack/CocoaLumberjack.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/DeviceKit/DeviceKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/MTBleCore/MTBleCore.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYApp/XYApp.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYCmd/XYCmd.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYCoreBluetooth/XYCoreBluetooth.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYExtension/XYExtension.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYGlucose/XYGlucose.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYLog/XYLog.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYNetwork/XYNetwork.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYStorage/XYStorage.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYUser/XYUser.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYUtil/XYUtil.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/XYWatchConnectivity/XYWatchConnectivity.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CocoaLumberjack/CocoaLumberjack.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/DeviceKit/DeviceKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/MTBleCore/MTBleCore.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYApp/XYApp.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYCmd/XYCmd.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYCoreBluetooth/XYCoreBluetooth.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYExtension/XYExtension.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYGlucose/XYGlucose.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYLog/XYLog.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYNetwork/XYNetwork.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYStorage/XYStorage.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYUser/XYUser.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYUtil/XYUtil.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/XYWatchConnectivity/XYWatchConnectivity.framework/Headers" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CocoaLumberjack" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/DeviceKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/MTBleCore" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYApp" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYCmd" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYCoreBluetooth" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYExtension" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYGlucose" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYLog" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYNetwork" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYStorage" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYUser" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYUtil" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/XYWatchConnectivity"
OTHER_LDFLAGS = $(inherited) -l"c++" -framework "CocoaLumberjack" -framework "CoreBluetooth" -framework "DeviceKit" -framework "Foundation" -framework "MTBleCore" -framework "UIKit" -framework "XYApp" -framework "XYCmd" -framework "XYCoreBluetooth" -framework "XYExtension" -framework "XYGlucose" -framework "XYLog" -framework "XYNetwork" -framework "XYStorage" -framework "XYUser" -framework "XYUtil" -framework "XYWatchConnectivity"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CocoaLumberjack" "-F${PODS_CONFIGURATION_BUILD_DIR}/DeviceKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/MTBleCore" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYApp" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYCmd" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYCoreBluetooth" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYExtension" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYGlucose" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYLog" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYNetwork" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYStorage" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYUser" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYUtil" "-F${PODS_CONFIGURATION_BUILD_DIR}/XYWatchConnectivity"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
